#: CommandOutputContext.cpp:127 CommandOutputContext.cpp:149
#, kde-kuit-format
msgctxt "@info"
msgid "Could not load page content"
msgstr "Klarte ikkje lasta inn sideinnhald"

#: CommandOutputContext.cpp:129
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Technical details: The <command>%1</command> tool is required to display "
"this page, but could not be found. You may be able to install it using your "
"package manager; either way, please report this packaging issue to %2."
msgstr ""
"Tekniske detaljar: Treng verktøyet <command>%1</command> for å visa denne "
"sida, men det er ikkje tilgjengeleg. Det kan vera du kan installera det via "
"pakke­handsamaren. Uansett bør du melda frå om denne pakke­feilen til %2."

#: CommandOutputContext.cpp:150
#, kde-kuit-format
msgctxt "@Info"
msgid ""
"Technical details: the <command>%1</command> tool crashed while generating "
"page content."
msgstr ""
"Tekniske detaljar: Verktøyet <command>%1</command> krasja ved generering av "
"sideinnhaldet."

